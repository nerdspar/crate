{
  "name": "crate",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "Crate — a wall-mounted touchscreen music shelf. Streaming library as album spines.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "dev:server": "npm run dev --workspace @crate/server",
    "dev:shelf": "npm run dev --workspace @crate/shelf",
    "dev:admin": "npm run dev --workspace @crate/admin"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "ws": "^8.21.0"
  }
}
