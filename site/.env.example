# Cloudflare Tunnel connector token.
# Cloudflare Zero Trust -> Networks -> Tunnels -> (your tunnel) -> Install connector,
# copy the token that follows `--token` (a long eyJ... string).
TUNNEL_TOKEN=

# Absolute path to the site folder on the host (Option A / bind-mount).
# Leave blank for local runs from this directory; on TrueNAS set the dataset path,
# e.g. SITE_DIR=/mnt/tank/apps/crate-site
SITE_DIR=
