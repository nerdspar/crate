# Copy to .env and fill in. (.env is git-ignored.)

# --- Music Assistant connection ---
# Your Music Assistant server's URL (default MA port is 8095).
#   External MA (e.g. on a NAS):        MA_URL=http://10.0.1.96:8095
#   Co-hosted MA (--profile cohosted):  MA_URL=http://host.docker.internal:8095
MA_URL=http://homeassistant.local:8095

# Long-lived MA token. Create one in the MA web UI (profile → long-lived tokens), or let
# Crate's onboarding create it. Needs an admin user so it can manage sources from Crate.
MA_TOKEN=

# --- Crate ---
# Port Crate serves the wall (/) and admin (/admin/) on.
CRATE_PORT=8080

# Set to 1 only when Crate co-hosts/manages MA (enables the MA restart affordance and,
# eventually, the co-hosted install path). Leave 0 for an external MA.
CRATE_MANAGES_MA=0

# Shown in the admin System view.
CRATE_VERSION=0.1.0
